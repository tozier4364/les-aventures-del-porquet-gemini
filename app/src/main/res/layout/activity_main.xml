
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6"
    android:padding="24dp">

    <!-- Título Amigable -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="BENVINGUT A\nLes Aventures del Porquet"
        android:textAlignment="center"
        android:textColor="#5D4037"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Personaje Central -->
    <ImageView
        android:id="@+id/ivPorquet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="40dp"
        android:contentDescription="Porquet haciendo el dab"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toTopOf="@+id/btnCatala"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        app:srcCompat="@drawable/porquet_dab" />

    <!-- Botón Català -->
    <Button
        android:id="@+id/btnCatala"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#FFFFFF"
        android:drawablePadding="12dp"
        android:elevation="4dp"
        android:text="Català"
        android:textAllCaps="false"
        android:textColor="#333333"
        android:textSize="22sp"
        android:stateListAnimator="@null"
        android:drawableStart="@android:drawable/ic_menu_help" 
        app:cornerRadius="40dp"
        app:layout_constraintBottom_toTopOf="@+id/btnCastellano"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <!-- Nota: Cambia android:drawableStart por tu vector de la Senyera -->

    <!-- Botón Castellano -->
    <Button
        android:id="@+id/btnCastellano"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#FFFFFF"
        android:drawablePadding="12dp"
        android:elevation="4dp"
        android:text="Castellano"
        android:textAllCaps="false"
        android:textColor="#333333"
        android:textSize="22sp"
        android:stateListAnimator="@null"
        android:drawableStart="@android:drawable/ic_menu_help"
        app:cornerRadius="40dp"
        app:layout_constraintBottom_toEndOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <!-- Nota: Cambia android:drawableStart por tu vector de la bandera de España -->

</androidx.constraintlayout.widget.ConstraintLayout>
